class Employee {
    String name;
    double basic, hra, da, total;

    Employee(String name, double basic) {
        this.name = name;
        this.basic = basic;
    }

    void calculateSalary() {
        hra = basic * 0.20;
        da = basic * 0.10;
        total = basic + hra + da;
    }

    void display() {
        System.out.println("Employee Name: " + name);
        System.out.println("Total Salary: ₹" + total);
    }

    public static void main(String[] args) {
        Employee e1 = new Employee("Arun", 20000);
        e1.calculateSalary();
        e1.display();
    }
}